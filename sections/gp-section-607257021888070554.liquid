      <style id="custom-css-ge3TCHaOJR">
        /* Wrapper */
.status {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Outer Circle */
.dot {
  width: 60px;
  height: 60px;
  background: #1f5f4a;
  border-radius: 50%;
  position: relative;
}

/* Inner Circle */
.dot::after {
  content: "";
  width: 35px;
  height: 35px;
  background: #00c853;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

/* Dotted Line */
.line {
  width: 0;
  height: 120px;
  border-left: 3px dotted #1f5f4a;
  margin-top: 4px;
}

/* Mobile */
@media (max-width: 600px) {
  .dot {
    width: 30px;
    height: 30px;
  }

  .dot::after {
    width: 18px;
    height: 18px;
  }

  .line {
    height: 90px;
  }
}

