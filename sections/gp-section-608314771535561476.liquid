      <script id="custom-js-gkm6iA-v5w">
        try {
          (function () {

  function isVisible(el) {
    const rect = el.getBoundingClientRect();
    return (
      rect.top < window.innerHeight &&
      rect.bottom > 0
    );
  }

  function startCounter(counter) {
    if (counter.dataset.started) return;
    counter.dataset.started = "true";

    const start = +counter.dataset.start;
    const end = +counter.dataset.end;
    const duration = +counter.dataset.duration;

    let startTime = null;

    function animate(time) {
      if (!startTime) startTime = time;
      const progress = Math.min((time - startTime) / duration, 1);
      counter.textContent = Math.floor(start + progress * (end - start));
      if (progress < 1) requestAnimationFrame(animate);
    }

    requestAnimationFrame(animate);
  }

  function checkCounters() {
    document.querySelectorAll(".gp-counter").forEach(counter => {
      if (isVisible(counter)) {
        startCounter(counter);
      }
    });
  }

  // keep checking (GemPages needs this)
  setInterval(checkCounters, 300);

})();

        } catch(err){}
      </script>
    
