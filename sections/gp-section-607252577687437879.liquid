      <style id="custom-css-gMNk8UnUeR">
        .video-box {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
}

.video-box video {
  width: 100%;
  display: block;
}

/* center button */
.play_btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  cursor: pointer;
  display: flex;
}

.play_btn img {
  width: 60px;
  height: 60px;
}
      </style>
    
      <script id="custom-js-gMNk8UnUeR">
        try {
          document.querySelectorAll(".video-box").forEach(box => {
  const video = box.querySelector("video");
  const btn = box.querySelector(".play_btn");

  btn.addEventListener("click", () => {
    // pause all videos
    document.querySelectorAll(".video-box video").forEach(v => v.pause());
