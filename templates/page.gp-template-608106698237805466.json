    "gp_section_608106989943260058": {
      "settings": {
        "checksum": "0bb465a222864e40571cc761a736360380b37ec9994731a1826576e5f1d7fe1e_1_1_0_0__1",
        "ggEEmq0HLtq_text": "<p>Austin Husband's 2-Year Search to Save His Wife From \"IBS\" Leads to <span style=\"color:#B22121;\"><strong>Forgotten Remedy</strong></span> That Exposed What Was Really Hiding Inside Her</p>",
        "ggGud5EvLC1_text": "<p><span style=\"color:rgba(5, 5, 5, 0.5);\">Health Alert › Austin, TX ›</span> Gut Health Breakthrough</p>",
        "ggLJ1BywQwX_text": "<p>Health &amp; Medicine Research Journalist</p>",
        "gge9qI_M9Y2_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0993/4700/5732/files/istockphoto-1147544807-612x612_copy.jpg",
        "ggp9N3avZzN_text": "<p>Written August 9th, 2025</p>",
        "ggr1GUR001Z_text": "<p>The ancient transdermal delivery method that dissolves the invisible \"fortress\" shielding parasites from every pill, capsule, and cleanse — and why the $24 billion gut health industry hopes you never learn about it</p>",
        "ggrgZhQ453B_text": "<p>Anna Leavy</p>",
        "ggsowT7YBjj_srcSet_desktop_src": "https://cdn.shopify.com/s/files/1/0993/4700/5732/files/istockphoto-1147544807-612x612.jpg"
      },
      "type": "gp-section-608106989943260058"
    },
    "gp_section_608109300434338359": {
      "settings": {
        "checksum": "fd2e761e8af0a9933e53c267af06f5e03f7db221af5eb393bcc5cfd8429af9bd_1_1_0_0__1",
