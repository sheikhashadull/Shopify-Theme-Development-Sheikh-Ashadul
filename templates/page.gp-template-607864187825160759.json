        "ggB8WacxXzr_text": "<p><strong>A Letter From Sarah, 2 Years Later</strong></p>",
        "ggCy1ZoLB6k_label": "<p><strong>CHECK AVAILABILITY</strong></p>",
        "ggDPt_J-fzO_text": "<p><strong>Endocrine Society.</strong> (n.d.). <i>Menopause and bone loss.</i></p><p>https://www.endocrine.org/patient-engagement/endocrine-library/menopause-and-bone-loss</p>",
