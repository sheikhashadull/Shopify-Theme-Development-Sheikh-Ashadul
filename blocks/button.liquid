{% liquid
  assign button_text = block.settings.button_text
  assign button_url = block.settings.button_url

  assign button_border_color = block.settings.button_border_color
  assign button_border = block.settings.button_border

  assign button_hover_border = block.settings.button_hover_border
  assign button_hover_color = block.settings.button_hover_color

  assign button_radius = block.settings.button_radius
  assign button_padding_top_bottom = block.settings.button_padding_top_bottom
  assign button_padding_left_right = block.settings.button_padding_left_right
  assign font_weight = block.settings.font_weight
  assign button_width = block.settings.button_width

  
%}

<a href="{{ button_url }}" class="btn-{{ block.id }}" {{ block.shopify_attributes }}>
  {{ button_text }}
</a>

{% style %}
  .btn-{{ block.id }}{
    padding: {{ button_padding_top_bottom }}px {{ button_padding_left_right }}px;
    background-color: rgb(var(--button));
    color: rgb(var(--button_text));
    font-size: 1rem;
    font-weight: {{ font_weight }};
    border-radius: {{ button_radius }}px;
    transition: all 0.3s ease;
    text-align: center;
    border: {{ button_border }}px solid {{ button_border_color }};
  }
  
  .btn-{{ block.id }}:hover {
    background-color: rgb(var(--secondary_button));
    color: rgb(var(--secondary_button_text));
    border: {{ button_hover_border }}px solid {{ button_hover_color }};
  }
{% endstyle %}

{% schema %}
{
  "name": "Button",
  "class": "text",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Button Content"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Button Style"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border Color",
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button Hover Color",
    },
    {
      "type": "header",
      "content": "Sizing"
    },
    {
      "type": "range",
      "id": "button_border",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Border",
      "default": 0
    },
    {
      "type": "range",
      "id": "button_radius",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Border Radius",
      "default": 5
    },
    {
      "type": "range",
      "id": "button_padding_top_bottom",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Padding Top/Bottom",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_padding_left_right",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Left/Right",
      "default": 30
    },

    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "100", "label": "Thin" },
        { "value": "200", "label": "Extra Light" },
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "button_width",
      "label": "Width",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "100%", "label": "Full Width" }
      ],
      "default": "auto"
    }
  ],
  "presets": [
    {
      "name": "Button"
    }
  ]
}
{% endschema %}
